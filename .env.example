# ===========================================
# 한국 공공도서관 현황 대시보드 - 환경변수 예시
# ===========================================
# 이 파일을 복사하여 .env.local 생성 후 값을 채우세요.

# --- 데이터베이스 (로컬 개발용 SQLite) ---
# Turso 미사용 시 로컬 SQLite 사용
DATABASE_URL="file:./prisma/dev.db"

# --- Turso (배포용 / 프로덕션) ---
# Turso 사용 시 아래 변수 설정
# DATABASE_URL는 무시되고 libsql 어댑터 사용
# TURSO_DATABASE_URL="libsql://your-db-name-your-user.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# --- NextAuth / Google OAuth ---
AUTH_SECRET="랜덤 32자 이상 문자열 생성: openssl rand -base64 32"
AUTH_GOOGLE_ID="Google Cloud Console에서 발급한 Client ID"
AUTH_GOOGLE_SECRET="Google Cloud Console에서 발급한 Client Secret"

# --- 이메일 로그인 (Google 콘솔 없이 사용 가능) ---
# 설정 시 허용 사용자(예: kts123@kookmin.ac.kr)가 이 비밀번호로 로그인 가능
# DEMO_PASSWORD="원하는비밀번호"

# --- Vercel 배포 시 ---
# Vercel 대시보드 Environment Variables에 위 변수들 추가
# AUTH_SECRET, AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET 필수
# Turso 사용 시 TURSO_DATABASE_URL, TURSO_AUTH_TOKEN 추가
